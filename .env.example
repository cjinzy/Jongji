# Jongji — Production Environment
# Copy this file to .env and fill in real values.

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=jongji
POSTGRES_USER=jongji
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Backend ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jongji:CHANGE_ME_STRONG_PASSWORD@postgres:5432/jongji
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY
SETUP_TOKEN=CHANGE_ME_SETUP_TOKEN

# ── Optional: Google OAuth ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/google/callback
