# Jongji — Development Environment

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=jongji
POSTGRES_USER=jongji
POSTGRES_PASSWORD=jongji

# ── Backend ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jongji:jongji@postgres:5432/jongji
SECRET_KEY=dev-secret-key
CORS_ORIGINS=["http://localhost:5173"]

# ── Optional: Google OAuth ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
