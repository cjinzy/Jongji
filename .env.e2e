# Jongji — E2E Testing Environment

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=jongji
POSTGRES_USER=jongji
POSTGRES_PASSWORD=jongji

# ── Backend ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jongji:jongji@postgres:5432/jongji
SECRET_KEY=e2e-test-secret-key
E2E_TESTING=true
AUTH_DISABLED=true
CORS_ORIGINS=["http://localhost:3100"]
